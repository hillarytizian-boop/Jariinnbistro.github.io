<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jari Inn Bistro | Luxury Hotel Ngong</title>

<link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">
<script src="https://cdn.tailwindcss.com"></script>

<script>
tailwind.config = {
theme: {
extend: {
colors: {
primary: '#1A3C34',
secondary: '#C5A059',
cream: '#F9F7F2'
},
fontFamily: {
sans: ['Lato'],
serif: ['Playfair Display']
}
}
}
}
</script>

<style>
body { font-family: 'Lato', sans-serif; background:#F9F7F2; }
.hero { background: linear-gradient(rgba(0,0,0,.6),rgba(0,0,0,.6)), url('https://images.unsplash.com/photo-1566073771259-6a8506099945'); background-size:cover; background-position:center; height:100vh; }
nav.scrolled { background: rgba(26,60,52,.95); }
</style>
</head>

<body class="antialiased">

<!-- NAV -->
<nav id="navbar" class="fixed w-full z-50 top-0 left-0 py-6 px-6 flex justify-between items-center text-white transition-all duration-300">
<div class="text-3xl font-serif font-bold">JARI <span class="text-secondary">INN</span></div>
<div class="hidden md:flex space-x-8 uppercase text-sm font-bold">
<a href="#home">Home</a>
<a href="#rooms">Rooms</a>
<a href="#menu">Menu</a>
<a href="#booking">Book</a>
</div>
</nav>

<!-- HERO -->
<section id="home" class="hero flex items-center justify-center text-center text-white">
<div>
<h1 class="text-5xl md:text-7xl font-serif mb-6">Jari Inn Bistro</h1>
<p class="mb-8 text-lg">Luxury Dining & Boutique Stay in Ngong</p>
<a href="#booking" class="bg-secondary px-8 py-3 uppercase text-sm font-bold">Book Now</a>
</div>
</section>

<!-- ROOMS -->
<section id="rooms" class="py-20 px-6 bg-white text-center">
<h2 class="text-4xl font-serif text-primary mb-12">Our Rooms</h2>
<div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">

<div class="bg-cream p-6 shadow">
<h3 class="font-serif text-xl mb-3">Deluxe Suite</h3>
<p class="text-secondary font-bold mb-3">$53 / Night</p>
<p>King bed, ensuite bathroom, city view.</p>
</div>

<div class="bg-cream p-6 shadow">
<h3 class="font-serif text-xl mb-3">Executive Room</h3>
<p class="text-secondary font-bold mb-3">$75 / Night</p>
<p>Perfect for business & comfort stay.</p>
</div>

<div class="bg-cream p-6 shadow">
<h3 class="font-serif text-xl mb-3">Presidential Suite</h3>
<p class="text-secondary font-bold mb-3">$120 / Night</p>
<p>Private balcony, jacuzzi & luxury lounge.</p>
</div>

</div>
</section>

<!-- MENU -->
<section id="menu" class="py-20 px-6 bg-cream text-center">
<h2 class="text-4xl font-serif text-primary mb-12">Restaurant Menu</h2>

<div class="flex justify-center gap-6 mb-10">
<button onclick="switchTab('breakfast')" class="menu-tab font-bold">Breakfast</button>
<button onclick="switchTab('lunch')" class="menu-tab font-bold">Lunch</button>
<button onclick="switchTab('dinner')" class="menu-tab font-bold">Dinner</button>
</div>

<div id="menu-content" class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto"></div>
</section>

<!-- BOOKING -->
<section id="booking" class="py-20 px-6 bg-primary text-white">
<div class="max-w-xl mx-auto bg-white text-gray-800 p-10 rounded shadow">

<h2 class="text-3xl font-serif text-primary mb-6">Book Your Stay</h2>

<form id="bookingForm">

<input type="date" id="checkin" required class="mb-4 w-full border p-2">
<input type="date" id="checkout" required class="mb-4 w-full border p-2">

<select id="guests" class="mb-4 w-full border p-2">
<option>1 Adult</option>
<option>2 Adults</option>
<option>Family (4+)</option>
</select>

<input type="text" id="fullname" placeholder="Full Name" required class="mb-4 w-full border p-2">
<input type="tel" id="phone" placeholder="Phone Number" required class="mb-6 w-full border p-2">

<button type="submit" class="w-full bg-primary text-white py-3 uppercase font-bold">
Confirm Booking
</button>

</form>
</div>
</section>

<!-- FOOTER -->
<footer class="bg-black text-white text-center py-6">
© 2026 Jari Inn Bistro
</footer>

<script>

window.addEventListener("scroll", function() {
const navbar = document.getElementById("navbar");
if (window.scrollY > 50) navbar.classList.add("scrolled");
else navbar.classList.remove("scrolled");
});

const menuItems = {
breakfast: [
{ name:"English Breakfast", price:"$12"},
{ name:"Pancakes & Honey", price:"$8"},
{ name:"Fruit Bowl", price:"$6"}
],
lunch: [
{ name:"Grilled Chicken", price:"$15"},
{ name:"Beef Burger", price:"$13"},
{ name:"Caesar Salad", price:"$10"}
],
dinner: [
{ name:"Steak & Vegetables", price:"$25"},
{ name:"Seafood Platter", price:"$30"},
{ name:"Pasta Alfredo", price:"$18"}
]
};

function switchTab(tab){
const content = document.getElementById("menu-content");
content.innerHTML="";
menuItems[tab].forEach(item=>{
content.innerHTML += `
<div class="bg-white p-6 shadow">
<h4 class="font-serif text-lg">${item.name}</h4>
<p class="text-secondary font-bold mt-2">${item.price}</p>
</div>`;
});
}

switchTab("breakfast");

document.getElementById("bookingForm").addEventListener("submit", function(e){
e.preventDefault();

const checkin = document.getElementById("checkin").value;
const checkout = document.getElementById("checkout").value;
const guests = document.getElementById("guests").value;
const fullname = document.getElementById("fullname").value;
const phone = document.getElementById("phone").value;

const message = `Hello Jari Inn Bistro,%0A%0A
New Booking:%0A
Name: ${fullname}%0A
Phone: ${phone}%0A
Check In: ${checkin}%0A
Check Out: ${checkout}%0A
Guests: ${guests}`;

const whatsappNumber = "254700000000"; // CHANGE TO YOUR REAL NUMBER

window.open(`https://wa.me/${whatsappNumber}?text=${message}`, "_blank");
});

</script>

</body>
</html>